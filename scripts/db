#!/bin/sh
# db — thin database layer for all agents
#
# Usage:
#   db query  <dbname> "<sql>"         — read query, returns rows as JSON
#   db exec   <dbname> "<sql>"         — write statement (INSERT/UPDATE/DELETE)
#   db script <dbname> <filepath.sql>  — run a .sql file
#
# Routing (first match wins):
#   1. $BRAIN_DATA_DIR/<name>.db exists  → direct sqlite3 (inside container)
#   2. $BRAIN_APP_URL set                → POST to BRAIN_APP_URL/api/db (local dev)
#
# The agent never has to guess paths. The server injects BRAIN_DATA_DIR with the
# tenant's container-side data dir (e.g. /data/users/<uuid>/data) before
# spawning the chat runtime, and inherits it into every Bash subagent.
#
# Local setup (add to ~/.zshrc) when running outside the container:
#   export BRAIN_APP_URL="https://my-brain-dashboard.fly.dev"
#   export BRAIN_API_TOKEN="<token from registry users.api_token>"

set -e

MODE="$1"
DBNAME="$2"
SQL="$3"

if [ -z "$MODE" ] || [ -z "$DBNAME" ]; then
  echo "Usage: db <query|exec|script> <dbname> <sql or filepath>" >&2
  exit 1
fi

# Resolve the DB file from the tenant data dir injected by the server.
DB_FILE=""
if [ -n "$BRAIN_DATA_DIR" ] && [ -f "${BRAIN_DATA_DIR}/${DBNAME}.db" ]; then
  DB_FILE="${BRAIN_DATA_DIR}/${DBNAME}.db"
fi

if [ -n "$DB_FILE" ]; then
  # ── Inside container: direct SQLite access ──────────────────────────────────
  case "$MODE" in
    query|exec)
      sqlite3 -json "$DB_FILE" "$SQL"
      ;;
    script)
      sqlite3 "$DB_FILE" < "$SQL"
      ;;
    *)
      echo "Unknown mode: $MODE. Use query, exec, or script." >&2
      exit 1
      ;;
  esac
  exit $?
fi

# ── No local DB found. Decide between hard error and HTTP fallback ──────────
# If we are clearly running inside the deployed container (BRAIN_DATA_DIR is
# set), the DB simply does not exist — surface that loudly instead of silently
# creating an empty file or quietly falling through to the HTTP API. This is
# the failure mode that previously made agents misdiagnose "wrong path" as
# "uninitialized schema".
if [ -n "$BRAIN_DATA_DIR" ]; then
  echo "Error: ${DBNAME}.db not found under \$BRAIN_DATA_DIR (${BRAIN_DATA_DIR})." >&2
  echo "       sqlite3 will not auto-create it; route schema work to Arc, or check the tenant data dir." >&2
  exit 2
fi

# ── Running locally: call the API ───────────────────────────────────────────
if [ -z "$BRAIN_APP_URL" ]; then
  echo "Error: BRAIN_APP_URL is not set and BRAIN_DATA_DIR points to no ${DBNAME}.db." >&2
  echo "       Set BRAIN_APP_URL (e.g. https://my-brain-dashboard.fly.dev) and BRAIN_API_TOKEN," >&2
  echo "       or run inside the container where BRAIN_DATA_DIR is injected by the server." >&2
  exit 1
fi
if [ -z "$BRAIN_API_TOKEN" ]; then
  echo "Error: BRAIN_API_TOKEN is not set. Add it to ~/.zshrc:" >&2
  echo "  export BRAIN_API_TOKEN=\"<token>\"" >&2
  exit 1
fi

case "$MODE" in
  query|exec)
    PAYLOAD=$(printf '{"db":"%s","sql":%s}' "$DBNAME" "$(printf '%s' "$SQL" | jq -Rs .)")
    curl -sf -X POST "${BRAIN_APP_URL}/api/db" \
      -H "Content-Type: application/json" \
      -H "Authorization: Bearer ${BRAIN_API_TOKEN}" \
      -d "$PAYLOAD"
    ;;
  script)
    PAYLOAD=$(printf '{"db":"%s","sql":%s}' "$DBNAME" "$(jq -Rs . < "$SQL")")
    curl -sf -X POST "${BRAIN_APP_URL}/api/db" \
      -H "Content-Type: application/json" \
      -H "Authorization: Bearer ${BRAIN_API_TOKEN}" \
      -d "$PAYLOAD"
    ;;
  *)
    echo "Unknown mode: $MODE. Use query, exec, or script." >&2
    exit 1
    ;;
esac
